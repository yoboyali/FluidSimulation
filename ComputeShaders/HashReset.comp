#version 460 core
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(std430, binding = 5) buffer CellStartBuffer {
    int cellStart[];
};

uniform uint tableSize;

void main() {
    uint index = gl_GlobalInvocationID.x;
    if (index <= tableSize) {
        cellStart[index] = 0;
    }
}